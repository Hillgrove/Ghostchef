@page
@model Ghostchef.Pages.Products.AllModel

@{
    ViewData["Title"] = "Færdigretter";
}

<h1 class="display-3 mb-5">@ViewData["Title"]</h1>

<div class="container">
    <div class="row">
        @foreach (var product in Model.Data)
        {
            var cardClass = product.InStock ? "card" : "card bg-light text-secondary";
            <div class="col-md-4 mb-3">
                <div class="@cardClass">
                    <div class="card-header">
                        @product.Name
                    </div>
                    <div class="card-body d-flex flex-column">
                        <p class="card-text">@product.Description</p>
                        <h6>Ingredienser</h6>
                        <ul>
                            @foreach (var ingredient in product.Ingredients)
                            {
                                <li>@ingredient.ToString()</li>
                            }
                        </ul>
                        <h6>Diæter</h6>
                        <ul>
                            @foreach (var diet in product.Diets)
                            {
                                <li>@diet.ToString()</li>
                            }
                        </ul>
                        <h6>Allergier</h6>
                        <ul>
                            @foreach (var allergy in product.Allergies)
                            {
                                <li>@allergy.ToString()</li>
                            }
                        </ul>
                        @if (!product.InStock)
                        {
                            <p class="text-danger" style="font-size: 20px; font-weight: bold;">UDSOLGT</p>
                        }
                        <h1 class="card-text">kr. @product.Price,-</h1>
                        <div>
                            <a class="btn btn-outline-danger btn-sm mt-3" type="button" title="Slet" asp-page="Delete" asp-route-id="@product.Id">Slet</a>
                            <a class="btn btn-outline-info btn-sm mt-3" type="button" title="Rediger" asp-page="Edit" asp-route-id="@product.Id">Rediger</a>
                        </div>
                        
                    </div>


                </div>
            </div>
        }
    </div>
</div>

<p>
    <a class="btn btn-outline-primary mt-3" asp-page="Create">Tilføj ny færdigret</a>
</p>
