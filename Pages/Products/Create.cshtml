@page
@model Ghostchef.Pages.Products.CreateModel

@{
    ViewData["Title"] = "Tilføj ny færdigret";
}

<h1 class="display-3 mb-5">@ViewData["Title"]</h1>

<form method="post">
    <div class="form-group mb-3">
        <label asp-for="Data.Name">Navn</label>
        <input asp-for="Data.Name" class="form-control" />
        <span asp-validation-for="Data.Name" class="text-danger"></span>
    </div>
    <div class="form-group mb-3">
        <label asp-for="Data.Description">Beskrivelse</label>
        <textarea asp-for="Data.Description" class="form-control"></textarea>
        <span asp-validation-for="Data.Description" class="text-danger"></span>
    </div>
    <div class="form-group form-check mb-3">
        <label>Ingredienser</label>
        @foreach (var ingrediens in Enum.GetValues(typeof(Ghostchef.Models.Ingredient)))
        {
            <div>
                <input type="checkbox" name="Ingredients" value="@ingrediens.ToString()" />
                <label>@ingrediens</label>
            </div>
        }
    </div>
    <div class="form-group form-check mb-3">
        <label>Diæter</label>
        @foreach (var diæt in Enum.GetValues(typeof(Ghostchef.Models.Diet)))
        {
            <div>
                <input type="checkbox" name="Diets" value="@diæt.ToString()" />
                <label>@diæt</label>
            </div>
        }
    </div>
    <div class="form-group form-check mb-3">
        <label>Allergier</label>
        @foreach (var allergi in Enum.GetValues(typeof(Ghostchef.Models.Allergy)))
        {
            <div>
                <input type="checkbox" name="Allergies" value="@allergi.ToString()" />
                <label>@allergi</label>
            </div>
        }
    </div>
    <div class="form-group mb-3">
        <label asp-for="Data.Description">Pris</label>
        <input asp-for="Data.Price" class="form-control"></input>
        <span asp-validation-for="Data.Price" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Opret</button>
</form>
